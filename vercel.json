{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npm run build:vercel",
    "outputDirectory": "dist/public",
    "installCommand": "npm install",
    "framework": null,
    "functions": {
        "api/**/*.ts": {
            "memory": 1024,
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}